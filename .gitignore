# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.coverage
.ruff_cache/
.ty_cache/

# Maturin develop build artifacts — dropped next to the Python source by
# `mise run solver:rebuild`; the real wheel goes through uv sync.
solver/solver-py/python/**/*.so
solver/solver-py/python/**/*.pyd
solver/solver-py/python/**/*.dylib

# Rust
target/

# Git worktrees (project-local)
.worktrees/

# Superpowers skill scratchpad (per-session brainstorm artifacts)
.superpowers/

# Local env files (backend)
backend/.env
backend/.env.local

# Playwright (frontend e2e)
frontend/e2e/.auth/
frontend/playwright-report/
frontend/test-results/

# Editors / OS
.DS_Store
.idea/
.vscode/

# Deployment secrets, real .env.staging lives on the VPS, not in git.
/deploy/.env.*
!/deploy/.env.*.example

# Local Claude Code scheduled-tasks lock file (per-machine state).
.claude/scheduled_tasks.lock
