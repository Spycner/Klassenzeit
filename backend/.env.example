# backend/.env.example
# Copy to backend/.env for local dev. Every KZ_* variable consumed by the
# backend's Settings class lives here.

# Dev DB — matches compose.yaml service
KZ_DATABASE_URL=postgresql+psycopg://klassenzeit:klassenzeit@localhost:5433/klassenzeit_dev
KZ_DB_POOL_SIZE=5
KZ_DB_MAX_OVERFLOW=10
KZ_DB_ECHO=false

# Auth
KZ_COOKIE_SECURE=false
KZ_SESSION_TTL_DAYS=14
KZ_PASSWORD_MIN_LENGTH=12
KZ_LOGIN_MAX_ATTEMPTS=5
KZ_LOGIN_LOCKOUT_MINUTES=15
