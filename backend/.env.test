# backend/.env.test
# Committed. Loaded explicitly by the pytest conftest. Points at the
# klassenzeit_test database alongside klassenzeit_dev in the same
# Postgres instance.

KZ_DATABASE_URL=postgresql+asyncpg://klassenzeit:klassenzeit@localhost:5433/klassenzeit_test
KZ_DB_ECHO=false
KZ_COOKIE_SECURE=false
KZ_SESSION_TTL_DAYS=1
KZ_LOGIN_MAX_ATTEMPTS=5
KZ_LOGIN_LOCKOUT_MINUTES=15
